{% extends "base.html.j2" %}

{% block title %}{{ job.title }} — IronVale Careers{% endblock %}

{% block content %}
<section class="section-pad">
    <div class="wrap">
        <p class="eyebrow"><a href="/careers.html" style="color: var(--iv-rust);">← All roles</a> / {{ job.department or "Open role" }}</p>
        <h1 style="max-width: 18ch; margin-bottom: var(--iv-px-5);">{{ job.title }}</h1>
        <p class="lead" style="max-width: 60ch; font-size: 1.2rem;">{{ job.brief or job.summary or "" }}</p>

        <div class="hero-stats" style="margin-top: var(--iv-px-6); max-width: 720px;">
            <div class="stat">
                <div class="stat-label">Department</div>
                <div class="stat-value" style="font-size: 1.4rem;">{{ job.department or "—" }}</div>
            </div>
            <div class="stat stat-accent">
                <div class="stat-label">Employment type</div>
                <div class="stat-value" style="font-size: 1.4rem;">{{ job.employment_type or "Full-time" }}</div>
            </div>
            {% if job.reports_to %}
            <div class="stat">
                <div class="stat-label">Reports to</div>
                <div class="stat-value" style="font-size: 1.4rem;">{{ job.reports_to }}</div>
            </div>
            {% endif %}
            <div class="stat stat-accent">
                <div class="stat-label">Location</div>
                <div class="stat-value" style="font-size: 1.4rem;">Perth + site</div>
            </div>
        </div>
    </div>
</section>

<section class="section-pad" style="background: var(--iv-bg-2);">
    <div class="wrap-narrow">
        {% if job.description %}
        <article class="prose">
            {{ job.description | markdown }}
        </article>
        {% endif %}
    </div>
</section>

<section class="cta-banner">
    <div class="wrap">
        <div class="cta-banner-inner">
            <div>
                <h2>Sound like you?</h2>
                <p>Submit your CV and a short cover letter. We read everything ourselves. Decisions within a week of interviews wrapping up.</p>
            </div>
            {% if company_url %}
            <a href="{{ company_url }}" class="btn btn-hivis btn-arrow cta-banner-btn">Apply via WorkReady</a>
            {% else %}
            <a href="/contact.html" class="btn btn-hivis btn-arrow cta-banner-btn">Get in touch</a>
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}
