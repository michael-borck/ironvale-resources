{% extends "base.html.j2" %}

{% block title %}Contact — IronVale Resources{% endblock %}

{% block content %}
<section class="section-pad">
    <div class="wrap">
        <p class="eyebrow">Contact</p>
        <h1 style="max-width: 16ch; margin-bottom: var(--iv-px-5);">Talk to us.</h1>
        <p class="lead" style="max-width: 60ch; font-size: 1.35rem;">Perth office, FIFO rotations to site. Mining hours — early starts and shorter days.</p>
    </div>
</section>

<section class="section-pad" style="background: var(--iv-bg-2);">
    <div class="wrap">
        <div class="feature-grid">
            <article class="feature">
                <div class="feature-num">01 / HQ</div>
                <h3>Perth office</h3>
                <p style="margin-bottom: var(--iv-px-2);">Level 14, 197 St Georges Terrace<br>Perth WA 6000</p>
                <p class="mono">+61 8 9000 0000</p>
            </article>
            <article class="feature">
                <div class="feature-num">02 / HOURS</div>
                <h3>Business hours</h3>
                <p style="margin-bottom: var(--iv-px-2);">Monday to Friday<br>07:00 — 15:00 AWST</p>
                <p class="mono">Mining schedule — early starts</p>
            </article>
            <article class="feature">
                <div class="feature-num">03 / EMAIL</div>
                <h3>General enquiries</h3>
                <p style="margin-bottom: var(--iv-px-2);">info@ironvaleresources.com.au</p>
                <p class="mono">Careers: careers@ironvaleresources.com.au</p>
            </article>
        </div>
    </div>
</section>

<section class="section-pad">
    <div class="wrap-narrow">
        <p class="eyebrow">Media & investors</p>
        <h2 style="margin-bottom: var(--iv-px-4);">For ASX disclosures and media.</h2>
        <p style="color: var(--iv-text-muted); font-size: 1.1rem; line-height: 1.7;">All ASX announcements are published through the ASX platform. Media enquiries and investor relations are handled through the Perth office. We don't have a dedicated PR firm — calls go to people who actually know what's happening on site.</p>
    </div>
</section>

<!-- AnythingLLM hiring desk chatbot -->
<script
  data-embed-id="2bd54118-0de9-421c-8024-dd876d21101c"
  data-base-api-url="https://chat.eduserver.au/api/embed"
  src="https://chat.eduserver.au/embed/anythingllm-chat-widget.min.js">
</script>
{% endblock %}
